{
  "tasks": {
    "strategy": "sequential",
    "max_retries": 3,
    "start": {
      "parallel": true,
      "description": "Initializing Step",
      "steps": [
        {
          "git": {
            "description": "Set up Git if not already set up",
            "script": null,
            "on_failure": null,
            "dependencies": []
          }
        },
        {
          "repository": {
            "description": "Install github repository for Medifab",
            "script": null
          }
        },
        {
          "docker": {
            "description": "Check if Docker is installed, if not install it",
            "script": null
          }
        },
        {
          "node": {
            "description": "Check if Node.js is installed, if not install it",
            "script": null
          }
        },
        {
          "dotnet": {
            "description": "Check if .NET is installed, if not install it",
            "script": null
          }
        }
      ]
    },
    "setup": {
      "parallel": false,
      "description": "Setup Step",
      "steps": [
        {
          "npm": {
            "description": "Run the installation script for Medifab",
            "script": "npm install"
          }
        },
        {
          "dotnet": {
            "description": "Run the installation script for Medifab",
            "script": "dotnet restore"
          }
        },
        {
          "docker": {
            "description": "Build the Docker images for Medifab",
            "script": "docker build -t medifab .",
            "dependencies": [
              "npm",
              "dotnet"
            ]
          }
        },
        {
          "compose": {
            "description": "Run the Docker Compose for Medifab",
            "script": "docker-compose up -d",
            "dependencies": [
              "docker"
            ]
          }
        }
      ]
    },
    "post": {
      "parallel": true,
      "description": "Post Installation Step",
      "steps": [
        {
          "healthcheck": {
            "description": "Check if the Medifab services are running properly",
            "script": "curl -f http://localhost:3000/health || exit 1",
            "dependencies": [
              "compose"
            ]
          }
        }
      ]
    }
  }
}
